---
import { Image } from 'astro:assets';
import me from '../assets/me.jpg';
import { content, getLangFromUrl } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const t = content[lang].home;
---
<section class="hero">
  <div class="hero-text">
    <p class="kicker fade-in">{t.kicker}</p>
    <h1 class="name fade-in delay-1">{t.name[0]}<br />{t.name[1]}</h1>
    <p class="role fade-in delay-2" set:html={t.role}></p>
    <p class="status fade-in delay-3">
      <span class="status-dot" aria-hidden="true"></span>
      <span set:html={t.status}></span>
    </p>

    <ul class="socials fade-in delay-4" aria-label="Social links">
      <li>
        <a href="https://www.linkedin.com/in/ronny-montano/" target="_blank" rel="me noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </li>
      <li>
        <a href="https://www.youtube.com/@ronny-montano" target="_blank" rel="me noopener noreferrer" aria-label="YouTube" title="YouTube">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/ronny-montano" target="_blank" rel="me noopener noreferrer" aria-label="GitHub" title="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
      </li>
      <li>
        <a href="mailto:rmontano1992@gmail.com" rel="me" aria-label="Email" title="Email">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
      </li>
    </ul>
  </div>

  <div class="hero-photo fade-in delay-2">
    <Image src={me} alt="Ronny Montano" width={360} height={360} class="avatar" loading="eager" />
    <div class="avatar-ring" aria-hidden="true"></div>
  </div>
</section>

<section data-reveal>
  <h2>{t.aboutTitle}</h2>
  {t.bio.map((p) => <p set:html={p}></p>)}
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: center;
    padding: 2rem 0 3rem;
    margin-bottom: 1rem;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -10%;
    width: 60%;
    aspect-ratio: 1;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 65%);
    z-index: -1;
    filter: blur(40px);
    pointer-events: none;
  }

  .kicker {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0 0 0.4rem;
    letter-spacing: 0;
  }

  .name {
    font-size: clamp(2.5rem, 1.4rem + 5.5vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
    font-weight: 700;
    margin: 0 0 1.1rem;
    color: var(--fg);
  }

  .role {
    font-size: 1.05rem;
    margin: 0 0 0.85rem;
    color: var(--fg-soft);
  }

  .status { margin: 0 0 1.5rem; }

  .hero-photo {
    position: relative;
    flex-shrink: 0;
  }

  .avatar {
    width: 168px;
    height: 168px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
    position: relative;
    z-index: 1;
  }

  .avatar-ring {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: conic-gradient(
      from 180deg,
      var(--accent) 0deg,
      transparent 120deg,
      transparent 240deg,
      var(--accent) 360deg
    );
    opacity: 0.18;
    z-index: 0;
    animation: rotate 14s linear infinite;
  }

  @keyframes rotate {
    to { transform: rotate(360deg); }
  }

  .socials {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
  }

  .socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    color: var(--muted);
    border: 1px solid var(--border);
    transition: color var(--dur) var(--ease-out),
                border-color var(--dur) var(--ease-out),
                background var(--dur) var(--ease-out),
                transform var(--dur) var(--ease-out);
  }

  .socials a:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .socials svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  @media (max-width: 640px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding-top: 1.25rem;
    }
    .hero-photo { order: -1; }
    .avatar { width: 120px; height: 120px; }
    .avatar-ring { inset: -7px; }
    .name { font-size: clamp(2.2rem, 4rem + 4vw, 3.4rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-ring { animation: none; }
  }
</style>
