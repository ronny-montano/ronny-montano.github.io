---
import { content, getLangFromUrl } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const t = content[lang].contact;

const email = t.channels.find((c) => c.label === 'Email');
const others = t.channels.filter((c) => c.label !== 'Email');
---
<section class="hero">
  <p class="kicker fade-in">{t.kicker}</p>
  <h1 class="display fade-in delay-1">
    {t.headline[0]}<br />
    <span class="grad">{t.headline[1]}</span>
  </h1>
  <p class="lede fade-in delay-2">{t.lede}</p>

  {email && (
    <a class="btn btn-primary fade-in delay-3" href={email.href}>
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <path fill="currentColor" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
      </svg>
      {email.value}
    </a>
  )}
</section>

<section data-reveal>
  <h2>{t.othersTitle}</h2>
  <ul class="channels">
    {others.map((l) => (
      <li>
        <a class="channel" href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
          <span class="ch-label">{l.label}</span>
          <span class="ch-value mono">{l.value}</span>
          <span class="ch-arrow" aria-hidden="true">↗</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .hero {
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: -10%;
    width: 60%;
    aspect-ratio: 1;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 60%);
    z-index: -1;
    filter: blur(40px);
    pointer-events: none;
  }

  .kicker {
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    font-weight: 600;
  }

  .display {
    font-size: clamp(2rem, 1rem + 4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin: 0 0 1.25rem;
    font-weight: 700;
  }

  .grad {
    background: linear-gradient(120deg, var(--accent) 0%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .lede {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 38rem;
    margin: 0 0 1.75rem;
  }

  .channels { list-style: none; padding: 0; margin: 0; }

  .channels li { border-top: 1px solid var(--border); }
  .channels li:last-child { border-bottom: 1px solid var(--border); }

  .channel {
    display: grid;
    grid-template-columns: 6rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 0.25rem;
    color: var(--fg);
    transition: padding var(--dur) var(--ease-out);
  }

  .channel:hover {
    text-decoration: none;
    padding-left: 0.75rem;
  }

  .channel:hover .ch-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .ch-label {
    font-weight: 500;
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ch-value {
    color: var(--fg);
    font-size: 0.97rem;
  }

  .ch-arrow {
    color: var(--muted);
    transition: color var(--dur) var(--ease-out),
                transform var(--dur) var(--ease-out);
  }

  @media (max-width: 540px) {
    .channel {
      grid-template-columns: 1fr auto;
      gap: 0.5rem;
    }
    .ch-label {
      grid-column: 1 / -1;
      font-size: 0.72rem;
    }
  }
</style>
