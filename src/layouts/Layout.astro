---
import '../styles/global.css';
import { content, getLangFromUrl, localizedPath, stripLangPrefix, langs, defaultLang } from '../i18n/content';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = content[lang];
const desc = description ?? t.home.meta.description;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const cleanPath = stripLangPrefix(path);

const siteUrl = 'https://ronny-montano.github.io';
const canonical = new URL(path === '/' ? '/' : path + '/', siteUrl).toString();

const alternates = langs.map((l) => ({
  lang: l,
  href: new URL(localizedPath(cleanPath, l).replace(/\/$/, '') + '/', siteUrl).toString(),
}));

const sameAs = [
  'https://www.linkedin.com/in/ronny-montano/',
  'https://www.youtube.com/@ronny-montano',
  'https://github.com/ronny-montano',
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ronny Montano',
  url: siteUrl,
  jobTitle: 'Odoo Engineer',
  worksFor: { '@type': 'Organization', name: 'Process Control' },
  knowsAbout: ['Odoo', 'Python', 'OWL', 'Flutter', 'Dart', 'Django'],
  sameAs,
};

// Para verificar la propiedad de la web en Google Search Console:
// 1. Ve a https://search.google.com/search-console
// 2. Añade la propiedad https://ronny-montano.github.io (tipo: prefijo de URL)
// 3. Elige el método "Etiqueta HTML"
// 4. Copia el valor del atributo content="..." y pégalo en la constante de abajo
const googleSiteVerification = '';

const nav = [
  { href: localizedPath('/', lang),          label: t.nav.home,      match: '/' },
  { href: localizedPath('/portfolio', lang), label: t.nav.portfolio, match: '/portfolio' },
  { href: localizedPath('/cv', lang),        label: t.nav.cv,        match: '/cv' },
  { href: localizedPath('/contact', lang),   label: t.nav.contact,   match: '/contact' },
];

function isActive(matchPath: string) {
  if (matchPath === '/') return cleanPath === '/';
  return cleanPath.startsWith(matchPath);
}

const otherLang = lang === 'es' ? 'en' : 'es';
const otherLangHref = localizedPath(cleanPath, otherLang);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
    <meta name="description" content={desc} />
    <meta name="author" content="Ronny Montano" />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Ronny Montano" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
    {sameAs.map((url) => <link rel="me" href={url} />)}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a class="brand" href={localizedPath('/', lang)}>Ronny Montano</a>
        <nav>
          {nav.map((item) => (
            <a href={item.href} class={isActive(item.match) ? 'active' : ''}>
              {item.label}
            </a>
          ))}
          <a class="lang-switch" href={otherLangHref} aria-label={t.switcher.aria}>
            <span class="lang-current">{lang === 'es' ? t.switcher.es : t.switcher.en}</span>
            <span class="lang-sep" aria-hidden="true">·</span>
            <span class="lang-other">{lang === 'es' ? t.switcher.en : t.switcher.es}</span>
          </a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="inner">
        <span>© {new Date().getFullYear()} Ronny Montano</span>
        <span class="muted mono" style="font-size: 0.78rem;">{t.footer.credit}</span>
      </div>
    </footer>

    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
      })();
    </script>

    <style>
      .lang-switch {
        margin-left: 0.4rem;
        padding: 0.4rem 0.7rem !important;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.04em;
      }
      .lang-switch:hover { background: var(--accent-soft); color: var(--fg); }
      .lang-current { color: var(--fg); }
      .lang-sep { color: var(--border-strong); }
      .lang-other { color: var(--muted); }
    </style>
  </body>
</html>
